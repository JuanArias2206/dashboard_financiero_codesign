# ─── ADATEC Dashboard Financiero — Variables de Entorno ───────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env al repositorio.
#
# Para trabajo colaborativo:
# 1. Clona el repositorio
# 2. Copia este archivo: cp .env.example .env
# 3. Pide las credenciales reales al administrador (no se comparten por git)
# 4. npm install
# 5. npm run dev (o vercel dev)
# ──────────────────────────────────────────────────────────────────────────────

# ─── DeepSeek AI ─────────────────────────────────────────────────────────────
# Obtén tu API key en https://platform.deepseek.com
# O pide la key compartida al administrador del proyecto
API_KEY_DS=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo disponible: deepseek-v4-flash (rápido/económico)
# También disponible: deepseek-chat, deepseek-reasoner
DEEPSEEK_MODEL=deepseek-v4-flash

# ─── RSales API (Datos en tiempo real) ───────────────────────────────────────
# ESTAS CREDENCIALES NO ESTÁN EN EL REPOSITORIO.
# Pídelas al administrador del proyecto o configura las tuyas propias.
RSALES_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RSALES_CLIENT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
RSALES_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RSALES_BASE_URL=https://api.ventasremotas.com/v1

# ─── Autenticación del Dashboard ─────────────────────────────────────────────
# Usuario y contraseña para acceder al dashboard web
DASHBOARD_USER=naprolab
DASHBOARD_PASSWORD=cambia_esta_contraseña

# Secreto para firmar sesiones JWT (usa una cadena aleatoria larga)
SESSION_SECRET=genera_una_clave_secreta_larga_y_aleatoria_aqui_minimo_32_caracteres

# Tiempo de vida de la sesión en milisegundos (por defecto 8 horas)
SESSION_TTL_MS=28800000

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001

# Origen permitido para CORS (en producción, pon tu dominio exacto)
ALLOWED_ORIGIN=*

# ─── Base de Datos SQL Server (opcional, solo para extracción de datos legacy) ─
# DB_SERVER=TU_SERVIDOR_SQL
# DB_USER=tu_usuario_lectura
# DB_PASSWORD=tu_contraseña_db
# DB_NAME=tu_base_de_datos
