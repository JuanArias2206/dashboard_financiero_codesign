# ─── ADATEC Dashboard Financiero — Variables de Entorno ───────────────────────
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas .env al repositorio.

# ─── DeepSeek AI ─────────────────────────────────────────────────────────────
# Obtén tu API key en https://platform.deepseek.com
API_KEY_DS=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo a usar: deepseek-chat (recomendado) o deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# ─── Autenticación del Dashboard ─────────────────────────────────────────────
# Usuario y contraseña para acceder al dashboard web
DASHBOARD_USER=naprolab
DASHBOARD_PASSWORD=cambia_esta_contraseña_en_produccion

# Secreto para firmar sesiones (usa una cadena aleatoria larga)
SESSION_SECRET=genera_una_clave_secreta_larga_y_aleatoria_aqui

# Tiempo de vida de la sesión en milisegundos (por defecto 8 horas)
SESSION_TTL_MS=28800000

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001

# Origen permitido para CORS (en producción, pon tu dominio exacto)
ALLOWED_ORIGIN=*

# ─── Base de Datos SQL Server (solo para scripts de extracción de datos) ──────
# Estas variables son opcionales — solo necesarias si regeneras cartera_export.xlsx
# DB_SERVER=TU_SERVIDOR_SQL
# DB_USER=tu_usuario_lectura
# DB_PASSWORD=tu_contraseña_db
# DB_NAME=tu_base_de_datos
