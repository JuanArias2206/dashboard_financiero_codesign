{
  "buildCommand": null,
  "outputDirectory": "public",
  "devCommand": "npm run serve",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/chatbot", "destination": "/chatbot.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/sync/rsales?cron=true&entity=all",
      "schedule": "0 6 * * *"
    }
  ]
}
