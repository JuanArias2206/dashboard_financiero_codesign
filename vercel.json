{
  "buildCommand": null,
  "outputDirectory": "public",
  "devCommand": "npm run serve",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/chatbot", "destination": "/chatbot.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/reports/*.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/sync/*.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
